---
import "@fontsource-variable/onest";
import "../styles/global.css";
import "../scripts/global.js";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

---

<!doctype html>
<html class="scroll-smooth overflow-y-scroll scrollbar-thin scrollbar-thumb-customGreen scrollbar-track-gray-300 scrollbar-rounded w-full p-0 m-0" lang="es">
    <head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="shortcut icon" href="/img/code.ico" type="image/x-icon" />

  <title>Leonel Caballero | Desarrollador Web Full Stack e Infraestructura</title>

  <meta name="description" content="Leonel Caballero, desarrollador web full stack e ingeniero en infraestructura con más de 5 años de experiencia. Desarrollo de sitios, tiendas online y soluciones robustas con despliegue profesional." />

  <!-- Canonical -->
  <link rel="canonical" href="https://leonelcaballero.com/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Leonel Caballero | Desarrollador Web Full Stack e Infraestructura" />
  <meta property="og:description" content="Desarrollador web full stack e ingeniero en infraestructura. +5 años creando soluciones web profesionales y escalables." />
  <meta property="og:image" content="https://leonelcaballero.com/img/og.png" />
  <meta property="og:url" content="https://leonelcaballero.com/" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Leonel Caballero | Desarrollador Web Full Stack e Infraestructura" />
  <meta name="twitter:description" content="Desarrollo web profesional e infraestructura sólida." />
  <meta name="twitter:image" content="https://leonelcaballero.com/img/og.png" />
</head>
    <body
        class="bg-custom-radial mx-auto px-auto"
    >
        <!-- Header -->
        <Header />

        <main
            class="container w-full bg-transparent md:px-4 lg:px-1"
        >
            <slot />
        </main>

        <!-- Footer -->
        <Footer />
    </body>
</html>
